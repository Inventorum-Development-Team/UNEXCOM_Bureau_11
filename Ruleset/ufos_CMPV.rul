#BEGIN SMALL SCOUT
  - type: STR_SMALL_SCOUT
    size: STR_VERY_SMALL
    sprite: 0
    damageMax: 50
    speedMax: 1800
    accel: 12
    avoidBonus: 10
    power: 15
    range: 20
    score: 50
    reload: 10
    breakOffTime: 200
    battlescapeTerrainData:
