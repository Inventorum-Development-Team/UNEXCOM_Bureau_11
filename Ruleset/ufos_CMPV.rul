        - IDT_A1UFO_TECHTIER3
        - IDT_A1UFO_TECHTIER4
        - IDT_A1UFO_TECHTIER5
      mapBlocks:
        - name: A_A1UFO1SCOUT2
          width: 10
          length: 10
          items:
            STR_MAP_GRENADE:
              - [2, 6, 1]
              - [6, 6, 1]
          fuseTimers:
            STR_MAP_GRENADE: [-2, -2]
